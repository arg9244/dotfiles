layout {

    focus-ring {
        active-color   "#ffb4ab"
        inactive-color "#1c100f"
        urgent-color   "#ffb4ab"
    }

    border {
        active-color   "#ffb4ab"
        inactive-color "#1c100f"
        urgent-color   "#ffb4ab"
    }

    shadow {
        color "#00000070"
    }

    tab-indicator {
        active-color   "#ffb4ab"
        inactive-color "#b33932"
        urgent-color   "#ffb4ab"
    }

    insert-hint {
        color "#ffb4ab80"
    }
}

recent-windows {
    highlight {
        active-color "#ffb4ab"
        urgent-color "#ffb4ab"
    }
}
